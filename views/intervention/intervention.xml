<odoo>

    <record id="intervention_list" model="ir.ui.view">
        <field name="name">intervention.list</field>
        <field name="model">intervention</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="date_demande"/>
                <field name="date_intervention"/>
                <field name="statut"/>
                <field name="priorite"/>
                <field name="technicien_id"/>
                <field name="client_id"/>
                <field name="rapport"/>
            </list>
        </field>
    </record>

    <record id="intervention_form" model="ir.ui.view">
        <field name="name">intervention.form</field>
        <field name="model">intervention</field>
        <field name="arch" type="xml">
            <form class="form">
                <sheet>
                    <button class="oe_button_box" name="statut_encours" string="Demarer" type="object"/>
                    <button class="oe_button_box" name="statut_terminee" string="terminer" type="object"/>
                    <group string="Information">
<!--                        <label for="name"/>-->
                        <field name="name"/>
<!--                        <label for="description"/>-->
                        <field name="description"/>
<!--                        <label for="priorite"/>-->
                        <field name="priorite"/>
<!--                        <label for="statut"/>-->
                        <field name="statut" widget="statusbar"/>

                    </group>

                    <group string="Gestion">
                        <field name="technicien_id"/>
                        <field name="client_id"/>
                        <field name="date_intervention"/>
                        <field name="date_demande"/>
                    </group>

                    <group string="Suivi technicien" invisible="statut != 'terminee'">
                        <field name="rapport" required="statut == 'terminee'"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>



</odoo>