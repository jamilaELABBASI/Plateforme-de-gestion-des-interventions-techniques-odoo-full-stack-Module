<odoo>

    <record id="intervention_list" model="ir.ui.view">
        <field name="name">intervention.list</field>
        <field name="model">intervention</field>
        <field name="arch" type="xml">

            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="date_demande"/>
                <field name="date_intervention"/>
                <field name="statut"/>
                <field name="priorite"/>
                <field name="technicien_id"/>
                <field name="client_id"/>
                <field name="rapport"/>
            </list>
        </field>
    </record>

    <record id="intervention_form" model="ir.ui.view">
        <field name="name">intervention.form</field>
        <field name="model">intervention</field>
        <field name="arch" type="xml">
            <form class="form_intervention">
                <header>
                    <button class="button" name="statut_encours" string="Démarrer" type="object"/>
                    <button class="button" name="statut_terminee" string="Terminer" type="object"/>
                </header>
                <sheet>
                    <group string="Information" class="center_group_title" >
                        <field name="name"/>
                        <field name="description"/>
                        <field name="priorite"/>
                         <field name="statut"  widget="statusbar"/>
                    </group>

                    <group string="Gestion" class="center_group_title">
                        <field name="technicien_id"/>
                        <field name="client_id"/>
                        <field name="date_intervention"/>
                        <field name="date_demande"/>
                    </group>

                    <group string="Suivi technicien" class="center_group_title" invisible="statut != 'terminee'">
                        <field name="rapport" required="statut == 'terminee'"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>



</odoo>