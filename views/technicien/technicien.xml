<odoo>
    <record id="technicien_list" model="ir.ui.view">
        <field name="name">technicien.list</field>
        <field name="model">technicien</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="competences"/>
                <field name="disponibilite"/>
                <field name="interventions_ids"/>
            </list>
        </field>
    </record>


    <record id="technicien_form" model="ir.ui.view">
        <field name="name">technicien.form</field>
        <field name="model">technicien</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="competences" widget="many2many_tags"/>
                        <field name="disponibilite"/>
                    </group>
                    <notebook>
                        <page string="Interventions">
                            <field name="interventions_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="statut"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>